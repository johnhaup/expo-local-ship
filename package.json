{
  "name": "@johnhaup/expo-ship",
  "version": "1.0.0",
  "description": "CLI to build and submit Expo apps locally",
  "private": false,
  "bin": {
    "expo-ship": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "tsup src/index.ts --format cjs --no-splitting --shims",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.4.1",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "expo",
    "eas",
    "build",
    "submit",
    "cli"
  ],
  "author": "John Haupenthal",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
